# SplitCircle AI Layer — environment template (Critical Rule #1: never commit real values)
# Copy to .env and fill in. In production these come from Secret Manager / ADC, not files.

# ── GCP ───────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1

# ── BigQuery ──────────────────────────────────────────────────────────────────
BQ_DATASET=splitcircle_ml

# ── Vertex AI ─────────────────────────────────────────────────────────────────
# 768-dim embedding model used for BOTH ingestion and query (must match).
EMBEDDING_MODEL=text-embedding-005
GENERATION_MODEL=gemini-2.5-flash
# From `gcloud ai index-endpoints` after DeployIndex:
VECTOR_INDEX_ID=
VECTOR_INDEX_ENDPOINT_ID=
VECTOR_DEPLOYED_INDEX_ID=sc_expense_memory_v1
# For a PUBLIC index endpoint, set to its publicEndpointDomainName (used by the
# RAG service's findNeighbors). Defaults to the regional aiplatform host.
VECTOR_ENDPOINT_HOST=

# ── Secrets (Secret Manager names; values never live here) ────────────────────
GEMINI_API_KEY=
MCP_SHARED_SECRET=

# ── MCP servers ───────────────────────────────────────────────────────────────
PORT=8080
# Firebase project used to verify client ID tokens (usually = GCP_PROJECT_ID).
FIREBASE_PROJECT_ID=your-project-id

# ── RAG ───────────────────────────────────────────────────────────────────────
RAG_TOP_K=10
RAG_CACHE_TTL_SECONDS=3600
REDIS_URL=
# RAG Cloud Run service URL the splitcircle-core MCP calls for semantic search.
# If unset, search_expenses falls back to a substring scan (no RAG).
RAG_SERVICE_URL=
# Shared secret for the MCP→RAG internal hop (set the SAME value on both).
RAG_SHARED_SECRET=

# ── Consolidated ingestion hook (functions/src/aiLayer.ts) ────────────────────
# The single `onGroupWritten` Cloud Function fans out to BQ sync + embedding +
# auto-categorize. It is a NO-OP until AI_LAYER_ENABLED=true, so it is safe to
# deploy before the backend exists. Set these in the Functions runtime env.
AI_LAYER_ENABLED=false
# Module specifier the orchestrator dynamically imports for the cores (the AI
# layer's compiled barrel, ai_layer/index.ts). Default resolves to ../ai_layer.
AI_LAYER_DIST=../ai_layer
# When enabled, also categorize only above this confidence:
CATEGORY_CONFIDENCE=0.6

# SplitCircle environment template
# Copy this file to `.env` and fill in real values.
# Only EXPO_PUBLIC_* variables belong here (they are bundled into client builds).

# Firebase (client/public config)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Google OAuth client IDs (public)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Optional legacy alias for Expo web client id (kept for backward compatibility)
# EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=

# Optional maps integration (public API key)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Calls: client should only know the token endpoint
EXPO_PUBLIC_LIVEKIT_TOKEN_ENDPOINT=

# OCR: client should only know your backend OCR proxy endpoint
EXPO_PUBLIC_OCR_PROXY_ENDPOINT=

# IMPORTANT:
# Do not place server secrets in this file (for example: LIVEKIT_API_SECRET).
# Store server-side credentials in Firebase Functions secrets instead:
#   firebase functions:secrets:set LIVEKIT_URL
#   firebase functions:secrets:set LIVEKIT_API_KEY
#   firebase functions:secrets:set LIVEKIT_API_SECRET

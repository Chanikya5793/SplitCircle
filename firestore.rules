rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function groupExists(groupId) {
      return exists(/databases/$(database)/documents/groups/$(groupId));
    }

    function isGroupMemberById(groupId) {
      return isSignedIn()
        && groupExists(groupId)
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;
    }

    function chatExists(chatId) {
      return exists(/databases/$(database)/documents/chats/$(chatId));
    }

    function isChatParticipantById(chatId) {
      return isSignedIn()
        && chatExists(chatId)
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
    }

    function isCurrentChatParticipant() {
      return isSignedIn() && request.auth.uid in resource.data.participantIds;
    }

    function isNewChatParticipant() {
      return isSignedIn() && request.auth.uid in request.resource.data.participantIds;
    }

    function isGroupJoinUpdate() {
      return isSignedIn()
        && !(request.auth.uid in resource.data.memberIds)
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.memberIds.hasAll(resource.data.memberIds)
        && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
        && request.resource.data.members.size() == resource.data.members.size() + 1
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'memberIds',
          'members',
          'updatedAt',
        ]);
    }

    function isGroupMutableUpdate(groupId) {
      return isGroupMemberById(groupId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name',
          'currency',
          'expenses',
          'settlements',
          'updatedAt',
        ])
        && request.resource.data.groupId == resource.data.groupId
        && request.resource.data.inviteCode == resource.data.inviteCode
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.memberIds == resource.data.memberIds
        && request.resource.data.members == resource.data.members
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function isGroupChatJoinUpdate() {
      return isSignedIn()
        && resource.data.type == 'group'
        && resource.data.groupId is string
        && isGroupMemberById(resource.data.groupId)
        && !(request.auth.uid in resource.data.participantIds)
        && request.auth.uid in request.resource.data.participantIds
        && request.resource.data.participantIds.hasAll(resource.data.participantIds)
        && request.resource.data.participantIds.size() == resource.data.participantIds.size() + 1
        && request.resource.data.participants.size() == resource.data.participants.size() + 1
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'participantIds',
          'participants',
          'lastMessage',
          'updatedAt',
        ]);
    }

    function isChatMutableUpdate() {
      return isCurrentChatParticipant()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'lastMessage',
          'updatedAt',
          'groupId',
          'unreadCount',
        ])
        && request.resource.data.chatId == resource.data.chatId
        && request.resource.data.type == resource.data.type
        && request.resource.data.participantIds == resource.data.participantIds
        && request.resource.data.participants == resource.data.participants;
    }

    match /users/{userId} {
      allow read, update, create: if isSelf(userId);
      allow delete: if false;
    }

    match /users/{userId}/notificationDevices/{deviceId} {
      allow read: if isSelf(userId);
      allow create, update, delete: if false;
    }

    match /groups/{groupId} {
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds;
      allow read: if isGroupMemberById(groupId);
      allow update: if isGroupMutableUpdate(groupId) || isGroupJoinUpdate();
      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;
    }

    match /groups/{groupId}/expenses/{expenseId} {
      allow read, create, update, delete: if isGroupMemberById(groupId);
    }

    match /chats/{chatId} {
      allow create: if isNewChatParticipant();
      allow read: if isCurrentChatParticipant();
      allow update: if isChatMutableUpdate() || isGroupChatJoinUpdate();
      allow delete: if false;
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read, create: if isChatParticipantById(chatId);
      allow update, delete: if false;
    }

    match /expenses/{expenseId} {
      allow create: if isSignedIn()
        && request.resource.data.groupId is string
        && isGroupMemberById(request.resource.data.groupId);
      allow read: if isSignedIn()
        && resource.data.groupId is string
        && isGroupMemberById(resource.data.groupId);
      allow update: if isSignedIn()
        && resource.data.groupId is string
        && request.resource.data.groupId is string
        && request.resource.data.groupId == resource.data.groupId
        && isGroupMemberById(resource.data.groupId);
      allow delete: if isSignedIn()
        && resource.data.groupId is string
        && isGroupMemberById(resource.data.groupId);
    }

    match /recurringBills/{billId} {
      allow create: if isSignedIn()
        && request.resource.data.groupId is string
        && isGroupMemberById(request.resource.data.groupId);
      allow read: if isSignedIn()
        && resource.data.groupId is string
        && isGroupMemberById(resource.data.groupId);
      allow update: if isSignedIn()
        && resource.data.groupId is string
        && request.resource.data.groupId is string
        && request.resource.data.groupId == resource.data.groupId
        && isGroupMemberById(resource.data.groupId);
      allow delete: if isSignedIn()
        && resource.data.groupId is string
        && isGroupMemberById(resource.data.groupId);
    }

    match /calls/{callId} {
      allow create: if isSignedIn()
        && request.resource.data.chatId is string
        && isChatParticipantById(request.resource.data.chatId);
      allow read, update, delete: if isSignedIn()
        && resource.data.chatId is string
        && isChatParticipantById(resource.data.chatId);
    }
  }
}

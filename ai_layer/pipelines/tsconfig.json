{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "embedding/embed_expenses.ts",
    "embedding/embedding_client.ts",
    "firestore_to_bq/sync_function.ts",
    "firestore_to_bq/backfill.ts",
    "__tests__/**/*.ts"
  ]
}
